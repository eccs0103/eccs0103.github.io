# Known, upstream, not fixable from this repo — do not re-investigate:
# - "npm warn deprecated prebuild-install@..." comes from @mtcute/node -> better-sqlite3,
#   present in every published @mtcute/node version including latest (checked 2026-07-16).
# - "npm warn allow-scripts .npmrc allow-scripts setting is being ignored..." comes from
#   environment-level npm config (no .npmrc existed in this repo before this file), not
#   something this repo can silence without hiding all future warnings via loglevel.
fund=false
