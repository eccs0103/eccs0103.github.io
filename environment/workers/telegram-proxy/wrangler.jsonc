{
	"name": "telegram-proxy",
	"main": "controllers/media-proxy-worker.ts",
	"compatibility_date": "2026-03-11",
	"upload_source_maps": true,
	"observability": {
		"enabled": true,
		"traces": {
			"enabled": true
		}
	},
	"vars": {
		"TELEGRAM_CHANNEL_ID": "-1003471238866"
	},
	"env": {
		"development": {
			"name": "telegram-proxy-development",
			"vars": {
				"TELEGRAM_CHANNEL_ID": "-1003772930485"
			}
		}
	}
}
